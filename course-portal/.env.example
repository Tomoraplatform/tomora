# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://make-extra-income-portal-topaz.vercel.app

# ─────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─────────────────────────────────────────────────────────────
# Paystack
# ─────────────────────────────────────────────────────────────
# Safe to use in the browser
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here
# Server-only. NEVER expose to the browser.
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here

# ─────────────────────────────────────────────────────────────
# Email — Brevo (default). Server-only key, never exposed to the browser.
# To use Resend/SendGrid instead, set EMAIL_PROVIDER=resend|sendgrid and
# provide EMAIL_API_KEY=... instead of BREVO_API_KEY.
# ─────────────────────────────────────────────────────────────
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
EMAIL_FROM=Make Extra Income with Claude AI <noreply@yourdomain.com>
FEEDBACK_RECIPIENT_EMAIL=tommyconcept4@gmail.com

# Only needed if EMAIL_PROVIDER is resend or sendgrid:
# EMAIL_API_KEY=

# ─────────────────────────────────────────────────────────────
# Admin & Course settings (course price/currency can also be edited in app_settings)
# ─────────────────────────────────────────────────────────────
# Admin access is free + passwordless (magic link). Any email listed here is an
# admin. Use a single email or a comma-separated list, e.g. a@x.com,b@y.com
ADMIN_EMAIL=you@yourdomain.com
# Display/charge price is fixed in code at ₦9,999 (999900 kobo). This is only a fallback.
COURSE_PRICE=9999
COURSE_CURRENCY=NGN
